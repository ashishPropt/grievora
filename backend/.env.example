PORT=3001
NODE_ENV=production

# PostgreSQL
DATABASE_URL=postgresql://grievora:CHANGE_ME@localhost:5432/grievora

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=CHANGE_ME_TO_STRONG_RANDOM_SECRET
JWT_EXPIRES_IN=7d

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...

# Serper (web search for provider resolution)
SERPER_API_KEY=

# Vultr Object Storage (S3-compatible)
VULTR_STORAGE_ENDPOINT=https://ewr1.vultrobjects.com
VULTR_STORAGE_ACCESS_KEY=
VULTR_STORAGE_SECRET_KEY=
VULTR_STORAGE_BUCKET=grievora-evidence

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Rate limits (requests per 15 min window)
RATE_LIMIT_GRIEVANCE=10
RATE_LIMIT_LOGIN=10
RATE_LIMIT_REGISTER=5
